# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
.claude/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.test.local.example
import.env

# playwright
/playwright-report
/test-results
/playwright/.cache

# supabase
/supabase/.temp/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# simulation logs
sim-log-*.json

# Phase 1 instrumentation captures (T-1777400000001) — local diagnostic dumps, not for repo
/docs/captures/

# Kanban Pro auto-generated (regenerated on project load — content lives in MMV-CONVENTIONS.md)
CLAUDE.md
README.md
AGENTS.md
/.github/copilot-instructions.md

# Tier 1 install backup dirs (created by install-tier1.sh — local rollback only)
.tier1-backup-*/
