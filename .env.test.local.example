# Copy to .env.test.local and fill in. Never commit credentials.
#
# Used by the Playwright integration tests (tests/e2e/*).
# The test user is a dedicated account; running the tests will reset its
# state. Do not use your primary play account.

TEST_USER_USERNAME=
TEST_USER_PASSWORD=

# Optional — override the baseURL to target a preview deployment or local dev.
# BASE_URL=http://localhost:3000
